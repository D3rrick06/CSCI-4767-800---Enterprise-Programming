CLASS zcl_employee_report DEFINITION
  PUBLIC FINAL CREATE PUBLIC.

  PUBLIC SECTION.
    INTERFACES if_oo_adt_classrun.
ENDCLASS.

CLASS zcl_employee_report IMPLEMENTATION.

  METHOD if_oo_adt_classrun~main.

    SELECT
      FROM z##_c_employeequearyp(
             p_target_curr = 'USD',
             p_date        = @sy-datum )
      FIELDS employeeid,
             firstname,
             lastname,
             departmentdescription,
             employeerole,
             monthlysalaryconverted,
             currencycode,
             companyaffiliation
      INTO TABLE @DATA(lt_employees).

    LOOP AT lt_employees INTO DATA(ls_emp).
      out->write( | Employee: { ls_emp-firstname } { ls_emp-lastname }| ).
      out->write( | Role: { ls_emp-employeerole }| ).
      out->write( | Department: { ls_emp-departmentdescription }| ).
      out->write( | Monthly Salary: { ls_emp-monthlysalaryconverted } { ls_emp-currencycode }| ).
      out->write( | Company Affiliation: { ls_emp-companyaffiliation } years| ).
      out->write( '-------------------------------------------' ).
    ENDLOOP.

  ENDMETHOD.

ENDCLASS.