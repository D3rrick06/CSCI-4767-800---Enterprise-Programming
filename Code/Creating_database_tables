@EndUserText.label : 'Employee'
@AbapCatalog.enhancement.category : #NOT_EXTENSIBLE
@AbapCatalog.tableCategory : #TRANSPARENT
@AbapCatalog.deliveryClass : #A
@AbapCatalog.dataMaintenance : #RESTRICTED
define table /lrn/employ {

  key client      : abap.clnt not null;
  key employee_id : /lrn/employee_id not null;
  first_name      : /dmo/first_name;
  last_name       : /dmo/last_name;
  birth_date      : z1039_birth_date;
  entry_date      : /lrn/entry_date;
  @Semantics.amount.currencyCode : '/lrn/employ.currency_code'
  annual_salary   : /lrn/annual_salary;
  currency_code   : waers;
  include /lrn/s_admin;
  key employee_id : z1039_employee_id;

}